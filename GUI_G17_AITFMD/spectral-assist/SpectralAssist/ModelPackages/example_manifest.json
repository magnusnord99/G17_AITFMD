{
  "schema_version": "1.0",

  "metadata": {
    "name": "baseline_3dcnn_bandavg",
    "version": "1.0.0",
    "created": "2026-03-24T11:37:01.505989+00:00",
    "author": "G17 AITFMD",
    "description": "Baseline 3D-CNN with band-average spectral reduction, trained on HSI dataset v1"
  },

  "pipeline": {
    "preprocessing": {
      "steps": ["calibrate", "clip", "neighbor_average", "tissue_mask", "band_average"],
      "params": {
        "calibration_epsilon": 1e-8,
        "clip_min": 0.0,
        "clip_max": 1.0,
        "neighbor_average_window": 3,
        "band_reduce_out_bands": 16,
        "band_reduce_strategy": "crop",
        "tissue_mask_method": "mean_std_percentile",
        "tissue_mask_q_mean": 0.5,
        "tissue_mask_q_std": 0.4,
        "tissue_mask_min_object_size": 1000,
        "tissue_mask_min_hole_size": 1000
      }
    },
    "spectral_reducer": {
      "method": "band_average",
      "embedded_in_onnx": false,
      "input_bands": 275,
      "output_bands": 16
    },
    "model": {
      "architecture": "baseline_3dcnn",
      "task": "classification",
      "total_parameters": 284930,
      "trainable_parameters": 284930,
      "layers": {
        "Conv3d": 4,
        "BatchNorm3d": 4,
        "Linear": 2,
        "Dropout": 2
      }
    }
  },

  "input_spec": {
    "input_rank": 5,
    "tensor_layout": "NCDHW",
    "input_shape": [1, 1, 16, 32, 32],
    "spectral_bands": 16,
    "spatial_patch_size": [32, 32],
    "dtype": "float32"
  },

  "output_spec": {
    "type": "logits",
    "num_classes": 2,
    "classes": ["normal", "anomaly"]
  },

  "training": {
    "dataset": "hsi_dataset_v1",
    "samples": 3210,
    "epochs": 50,
    "metrics": {
      "accuracy": 0.938,
      "precision": 0.0,
      "recall": 0.0,
      "f1": 0.0
    }
  },

  "artifacts": {
    "model_onnx": "model.onnx",
    "validation_expected_json": "validation_sample_expected.json",
    "validation_patch_raw_bin": "validation_sample_patch_raw_hwc_f32.bin"
  },

  "validation": {
    "status": "pending",
    "result": null
  }
}
