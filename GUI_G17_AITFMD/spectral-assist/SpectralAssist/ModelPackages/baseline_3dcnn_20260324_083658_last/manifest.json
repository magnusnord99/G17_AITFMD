{
  "schema_version": "1.2",

  "metadata": {
    "name": "baseline_3dcnn_bandavg",
    "version": "1.0.0",
    "created": "2026-03-24T11:37:01.505989+00:00",
    "author": "G17 AITFMD",
    "description": "Baseline 3D-CNN with band-average spectral reduction, trained on HSI dataset v1",
    "tags": ["3dcnn", "band-average", "binary-classification"]
  },

  "pipeline": {
    "preprocessing": {
      "steps": ["calibrate", "clip", "neighbor_average", "tissue_mask", "band_average"],
      "params": {
        "calibration_epsilon": 1e-8,
        "clip_min": 0.0,
        "clip_max": 1.0,
        "neighbor_average_window": 3,
        "band_reduce_out_bands": 16,
        "band_reduce_strategy": "crop",
        "tissue_mask_method": "mean_std_percentile",
        "tissue_mask_q_mean": 0.5,
        "tissue_mask_q_std": 0.4,
        "tissue_mask_min_object_size": 1000,
        "tissue_mask_min_hole_size": 1000
      }
    },
    "spectral_reducer": {
      "method": "band_average",
      "embedded_in_onnx": false,
      "input_bands": 275,
      "output_bands": 16
    },
    "classifier": {
      "architecture": "baseline_3dcnn",
      "patch_size": [32, 32]
    }
  },

  "input_spec": {
    "input_rank": 5,
    "tensor_layout": "NCDHW",
    "input_shape": [1, 1, 16, 32, 32],
    "spectral_bands": 16,
    "expected_bands": 16,
    "spatial_patch_size": [32, 32],
    "dtype": "float32"
  },

  "output_spec": {
    "type": "logits",
    "num_classes": 2,
    "classes": ["normal", "anomaly"]
  },

  "artifacts": {
    "model_onnx": "model.onnx"
  },

  "training": {
    "dataset": "hsi_dataset_v1",
    "samples": 3210,
    "epochs": 50,
    "val_accuracy": 0.938
  }
}
