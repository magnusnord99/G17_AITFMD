<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpectralAssist.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SpectralAssist.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SpectralAssist">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
        to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainViewModel />
    </Design.DataContext>

    <Grid>
        <!-- Main Layout -->
        <Grid ColumnDefinitions="Auto,*">

            <!-- LEFT: Sidebar -->
            <Border Grid.Column="0"
                    Background="#1A1A1A"
                    BorderBrush="#2D2D2D"
                    BorderThickness="0,0,1,0"
                    Padding="8,12">
                <DockPanel LastChildFill="False">

                    <!-- App Logo -->
                    <StackPanel DockPanel.Dock="Top" Spacing="4">
                        <TextBlock Text="SpectralAssist"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#CCCCCC"
                                   Margin="4,0,4,8" />

                        <Border Height="1" Background="#2D2D2D" Margin="0,0,0,4" />

                        <!-- Navigational Buttons -->
                        <Button Content="Home"
                                Command="{Binding NavigateToHomeCommand}"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="8,6"
                                CornerRadius="4" />

                        <Button Content="Models"
                                Command="{Binding NavigateToModelsCommand}"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="8,6"
                                CornerRadius="4" />

                        <Border Height="1" Background="#2D2D2D" Margin="0,8,0,4" />

                        <!-- Action Buttons -->
                        <Button Content="Open HSI"
                                Click="OpenHSIButton_Clicked"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="8,6"
                                CornerRadius="4" />

                        <Button Content="Run Inference"
                                Command="{Binding RunInferenceCommand}"
                                Background="#2D2D2D"
                                Foreground="#CCCCCC"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="8,6"
                                CornerRadius="4"
                                IsEnabled="{Binding HasImageView}" />

                        <TextBlock Text="{Binding ActiveModel.DisplayName, FallbackValue='No model selected'}"
                                   FontSize="11"
                                   Foreground="#888"
                                   Margin="16,0,16,4" />
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- RIGHT: Dynamic Content -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}" />
        </Grid>


        <!-- Drag and Drop Overlay -->
        <Border IsVisible="{Binding IsDragging}"
                IsHitTestVisible="False"
                Background="#CC000000"
                CornerRadius="8"
                Margin="16">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <TextBlock Text="{Binding DragIcon}"
                           FontSize="48"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding DragMessage}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center" />
            </StackPanel>

        </Border>

    </Grid>

</Window>