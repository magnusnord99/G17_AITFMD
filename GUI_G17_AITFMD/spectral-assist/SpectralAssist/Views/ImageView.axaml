<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SpectralAssist.ViewModels"
             xmlns:paz="using:Avalonia.Controls.PanAndZoom"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SpectralAssist.Views.ImageView"
             x:DataType="vm:ImageViewModel">

    <Panel>
        <!-- Loading State -->
        <StackPanel IsVisible="{Binding IsLoading}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
            <TextBlock Text="{Binding StatusMessage}"
                       HorizontalAlignment="Center"
                       Foreground="#AAAAAA"/>
            <ProgressBar Value="{Binding Progress}"
                         Minimum="0" Maximum="1"
                         Width="300" Height="4"/>
        </StackPanel>

        <!-- Error State -->
        <StackPanel IsVisible="{Binding IsError}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
            <TextBlock Text="⚠" FontSize="48"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#FF6B6B"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Ready State -->
        <Grid IsVisible="{Binding IsReady}"
              RowDefinitions="Auto,*,Auto,Auto">

            <!-- Top Metadata Bar -->
            <Border Grid.Row="0"
                    Background="#1E1E1E"
                    BorderBrush="#2D2D2D"
                    BorderThickness="0,0,0,1"
                    Padding="12,6">
                
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <TextBlock Foreground="#888888" FontSize="11">
                        <Run Text="Description: "/>
                        <Run Text="{Binding Cube.Header.Description}" Foreground="#CCCCCC"/>
                    </TextBlock>
                    <TextBlock Text="Dimensions:" Foreground="#888888" FontSize="11"/>
                    <TextBlock Text="{Binding Cube.Header.Samples}" Foreground="#CCCCCC" FontSize="11"/>
                    <TextBlock Text="×" Foreground="#888888" FontSize="11"/>
                    <TextBlock Text="{Binding Cube.Header.Lines}" Foreground="#CCCCCC" FontSize="11"/>
                    <TextBlock Text="×" Foreground="#888888" FontSize="11"/>
                    <TextBlock Text="{Binding Cube.Header.Bands}" Foreground="#CCCCCC" FontSize="11"/>
                </StackPanel>
                
            </Border>

            <!-- Image Display -->
            <paz:ZoomBorder x:Name="ZoomBorder" Grid.Row="1"
                            Background="#121212"
                            Stretch="None"
                            BoundsMode="KeepContentVisible"
                            ClipToBounds="True"
                            EnableConstrains="True"
                            
                            EnablePan="True"
                            PanButton="Left"
                            
                            ZoomSpeed="1.05"
                            MinZoomX="1.0"
                            MinZoomY="1.0"
                            MaxZoomX="50"
                            MaxZoomY="50">
                <Grid>
                    <Image Source="{Binding CurrentBitmap}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                    <Image Source="{Binding OverlayBitmap}"
                           Opacity="{Binding OverlayOpacity}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsVisible="{Binding ShowOverlay}"/>
                </Grid>
            </paz:ZoomBorder>

            <!-- Inference Output (hidden when empty) -->
            <Border Grid.Row="2"
                    Background="#1A1A1A"
                    BorderBrush="#2D2D2D"
                    BorderThickness="0,1,0,0"
                    Padding="12,8"
                    MaxHeight="120"
                    IsVisible="{Binding InferenceOutput, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding InferenceOutput}"
                               TextWrapping="Wrap"
                               FontFamily="Consolas"
                               FontSize="11"
                               Foreground="#E0E0E0"/>
                </ScrollViewer>
            </Border>
            
            <!-- Bottom Toolbar -->
            <Border Grid.Row="3"
                    Background="#1E1E1E"
                    BorderBrush="#2D2D2D"
                    BorderThickness="0,1,0,0"
                    Padding="12,6"
                    MinHeight="64">
                <Grid ColumnDefinitions="250,*,450">

                    <!-- Left: Display mode + band info -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">

                        <ToggleSwitch OnContent="Spectral"
                                      OffContent="RGB"
                                      IsChecked="{Binding IsGrayscale, Mode=TwoWay}"
                                      Padding="0"
                                      MinWidth="0"/>

                        <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding IsGrayscale}"
                                    Spacing="4">
                            <TextBlock Text="{Binding SelectedBand, StringFormat='Band: {0}'}"
                                       VerticalAlignment="Center"
                                       Foreground="#CCCCCC"
                                       FontSize="11"
                                       Width="65"
                                       TextAlignment="Right"/>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="#CCCCCC"
                                       FontSize="11"
                                       Width="75"
                                       TextAlignment="Right">
                                <Run Text="λ: "/>
                                <Run Text="{Binding SelectedBandWaveLength, StringFormat='{}{0:F1}'}"/>
                                <Run Text="{Binding WavelengthUnit}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- Center: Band slider -->
                    <Slider Grid.Column="1"
                          IsVisible="{Binding IsGrayscale}"
                          Margin="12,0,12,0"
                          Minimum="0"
                          Maximum="{Binding MaxBandIndex}"
                          Value="{Binding SelectedBand}"
                          TickFrequency="1"
                          IsSnapToTickEnabled="True"
                          VerticalAlignment="Center"/>

                    <!-- Right: Inference + Overlay controls -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">

                        <Button Content="Run Inference"
                                Command="{Binding RunInferenceCommand}"
                                Background="#2D2D2D"
                                Foreground="#CCCCCC"
                                Padding="8,2"
                                CornerRadius="4"
                                FontSize="11"
                                VerticalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    IsVisible="{Binding ClassificationResult,
                                                Converter={x:Static ObjectConverters.IsNotNull}}">

                            <Border Width="1" Background="#2D2D2D" Margin="4,2"/>

                            <ToggleSwitch OnContent="Overlay"
                                          OffContent="Overlay"
                                          IsChecked="{Binding ShowOverlay}"
                                          Padding="0"
                                          MinWidth="0"
                                          FontSize="11"/>

                            <TextBlock Text="Opacity:"
                                       VerticalAlignment="Center"
                                       Foreground="#888888"
                                       FontSize="11"
                                       IsEnabled="{Binding ShowOverlay}"/>

                            <Slider Value="{Binding OverlayOpacity}"
                                    Minimum="0" Maximum="1"
                                    Width="100"
                                    VerticalAlignment="Center"
                                    IsEnabled="{Binding ShowOverlay}"/>

                            <TextBlock Text="{Binding OverlayOpacity, StringFormat='{}{0:P0}'}"
                                       VerticalAlignment="Center"
                                       Foreground="#CCCCCC"
                                       FontSize="11"
                                       Width="35"
                                       IsEnabled="{Binding ShowOverlay}"/>
                        </StackPanel>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
    </Panel>
</UserControl>
